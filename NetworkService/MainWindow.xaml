<Window x:Class="NetworkService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NetworkService"
        xmlns:views="clr-namespace:NetworkService.Views"
        xmlns:viewmodels="clr-namespace:NetworkService.ViewModel"
        xmlns:converters="clr-namespace:NetworkService.Converters"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        xmlns:notifications="clr-namespace:Notification.Wpf.Controls;assembly=Notification.Wpf"
        mc:Ignorable="d"
        WindowStyle="None"
        Background="{StaticResource InputBackgroundBrush}"
        Title="MainWindow" Height="650" Width="800">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="Z"
                    Modifiers="Ctrl"
                    Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Tab"
                    Modifiers="Ctrl"
                    Command="{Binding NavPrevCommand}"/>
        <KeyBinding Key="Delete"
                    Modifiers="Ctrl"
                    Command="{Binding CloseCommand}"/>
        <KeyBinding Key="Left"
                    Modifiers="Alt"
                    Command="{Binding NavDirectionCommand}"
                    CommandParameter="left"/>
        <KeyBinding Key="Right"
                    Modifiers="Alt"
                    Command="{Binding NavDirectionCommand}"
                    CommandParameter="right"/>
    </Window.InputBindings>
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:MeasurementGraphViewModel}">
            <views:MeasurmentGraphView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:NetworkDisplayViewModel}">
            <views:NetworkDisplayView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:NetworkEntitiesViewModel}">
            <views:NetworkEntitiesView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:DialogViewModel}">
            <views:ConfirmActionView/>
        </DataTemplate>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DialogViewModel, Converter={StaticResource NullToBoolConverter}}" Value="True">
                        <Setter Property="Focusable" 
                                Value="False"/>
                        <Setter Property="KeyboardNavigation.DirectionalNavigation" 
                                Value="None"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>
        <notifications:NotificationArea MaxItems="3"
                                        IsTabStop="False"
                                        Position="TopRight"
                                        Grid.RowSpan="2"
                                        Name="WindowNotificationArea"
                                        Panel.ZIndex="999"/>

        <Grid Background="#A0000000" 
              Grid.RowSpan="3" 
              Panel.ZIndex="1000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility"
                            Value="Collapsed"/>
                    <Setter Property="KeyboardNavigation.TabNavigation"
                            Value="Cycle"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DialogViewModel, Converter={StaticResource NullToBoolConverter}}" Value="True">
                            <Setter Property="Visibility"
                                    Value="Visible"/>
                            <Setter Property="FocusManager.FocusedElement"
                                    Value="{Binding ElementName=DialogContainer}"/>
                            <Setter Property="KeyboardNavigation.DirectionalNavigation" 
                                    Value="Cycle"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <ContentControl x:Name="DialogContainer"
                            IsTabStop="False"
                            Content="{Binding DialogViewModel}"
                            Height="150"
                            Width="250"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
        </Grid>

        <Grid Background="{StaticResource HeaderBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Label Content="NetworkService"
                   Style="{StaticResource MainHeaderLabelStyle}"/>
            <Button Grid.Column="1"
                    Content="Entity"
                    Command="{Binding NavCommand}"
                    CommandParameter="entity"
                    Style="{StaticResource NavigationButtonStyle}"/>

            <Button Grid.Column="2"
                    Content="Display"
                    Command="{Binding NavCommand}"
                    CommandParameter="display"
                    Style="{StaticResource NavigationButtonStyle}"/>

            <Button Grid.Column="3"
                    Content="Graph"
                    Command="{Binding NavCommand}"
                    CommandParameter="graph"
                    Style="{StaticResource NavigationButtonStyle}"/>

            <Button Grid.Column="4"
                    Content="Undo"
                    IsTabStop="False"
                    Command="{Binding UndoCommand}"
                    Style="{StaticResource ConfirmButtonStyle}"/>

            <Button Grid.Column="5"
                    Content="Close"
                    IsTabStop="False"
                    Style="{StaticResource CancelButtonStyle}"
                    Command="{Binding CloseCommand}"/>

        </Grid>
        <ContentControl Grid.Row="1" 
                        Content="{Binding CurrentViewModel}"
                        IsTabStop="False"/>
        <views:TerminalView Grid.Row="2"
                            IsTabStop="False"/>
    </Grid>
</Window>
