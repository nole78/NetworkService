<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color1">#3E5F44</Color>
    <Color x:Key="Color2">#5E936C</Color>
    <Color x:Key="Color3">#93DA97</Color>
    <Color x:Key="Color4">#E8FFD7</Color>
    <Color x:Key="ErrorColor3">#FF999C</Color>
    <Color x:Key="ErrorColor1">Red</Color>
    <Color x:Key="ErrorColor2">DarkRed</Color>
    <Color x:Key="SelectedColor">Cyan</Color>
    <Color x:Key="DrawingModColor">#E2FFFE</Color>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Color1}"/>
    <SolidColorBrush x:Key="TextDisplayBrush" Color="{StaticResource Color1}"/>
    <SolidColorBrush x:Key="TextInputBrush" Color="{StaticResource Color2}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Color3}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource Color4}"/>

    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource Color1}"/>
    <SolidColorBrush x:Key="HeaderTextBrush" Color="{StaticResource Color3}"/>

    <SolidColorBrush x:Key="SelectedBorderBrush" Color="{StaticResource SelectedColor}"/>
    <SolidColorBrush x:Key="DrawingModBrush" Color="{StaticResource DrawingModColor}"/>

    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorColor1}"/>
    <SolidColorBrush x:Key="ErrorBorderBrush" Color="{StaticResource ErrorColor2}"/>
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{StaticResource ErrorColor3}"/>

</ResourceDictionary>