<UserControl x:Class="NetworkService.Views.MeasurmentGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             xmlns:converters="clr-namespace:NetworkService.Converters"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:viewmodels="clr-namespace:NetworkService.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <UserControl.DataContext>
        <viewmodels:MeasurementGraphViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:AddValueConverter x:Key="AddValueConverter"/>
        <ControlTemplate x:Key="GraphNode" TargetType="ContentControl">
            <Grid>
                <TextBlock Text="{Binding Content.Value, RelativeSource={RelativeSource TemplatedParent}}"
                           Panel.ZIndex="2"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"/>
                <Rectangle RadiusX="50" RadiusY="50" 
                           Width="30" Height="30" 
                           Stroke="Black">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Fill" Value="Lime"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Content.IsValid, RelativeSource={RelativeSource TemplatedParent}}" Value="False">
                                    <Setter Property="Fill"
                                            Value="Red"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Content.IsVisible, RelativeSource={RelativeSource TemplatedParent}}" Value="False">
                                <Setter Property="Visibility"
                                            Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
            </Grid>
        </ControlTemplate>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Label Style="{StaticResource HeaderLabelStyle}"
               Content="Measuring Graph"
               HorizontalAlignment="Left"
               Margin="5 0 0 0"/>

        <Grid Grid.Row="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Label Content="Resource"/>
            <ComboBox Grid.Row="1" 
                      ItemsSource="{Binding Resources}"
                      SelectedItem="{Binding SelectedResource}"
                      Style="{StaticResource ComboStyle}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Id, StringFormat='#{0} '}"/>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <Canvas Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Margin="5" 
                Background="{StaticResource TextInputBrush}">

            <Line Stroke="Black" StrokeThickness="2"
                  X1="{Binding (Canvas.Left), ElementName=Circle1, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  Y1="{Binding (Canvas.Top), ElementName=Circle1, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  X2="{Binding (Canvas.Left), ElementName=Circle2, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  Y2="{Binding (Canvas.Top), ElementName=Circle2, Converter={StaticResource AddValueConverter}, ConverterParameter=15}">
                <Line.Style>
                    <Style  TargetType="Line">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Nodes[1].IsVisible}" Value="False">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Line.Style>
            </Line>

            <Line Stroke="Black" StrokeThickness="2"
                  X1="{Binding (Canvas.Left), ElementName=Circle2, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  Y1="{Binding (Canvas.Top), ElementName=Circle2, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  X2="{Binding (Canvas.Left), ElementName=Circle3, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  Y2="{Binding (Canvas.Top), ElementName=Circle3, Converter={StaticResource AddValueConverter}, ConverterParameter=15}">
                <Line.Style>
                    <Style  TargetType="Line">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Nodes[2].IsVisible}" Value="False">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Line.Style>
            </Line>

            <Line Stroke="Black" StrokeThickness="2"
                  X1="{Binding (Canvas.Left), ElementName=Circle3, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  Y1="{Binding (Canvas.Top), ElementName=Circle3, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  X2="{Binding (Canvas.Left), ElementName=Circle4, Converter={StaticResource AddValueConverter}, ConverterParameter=15}"
                  Y2="{Binding (Canvas.Top), ElementName=Circle4, Converter={StaticResource AddValueConverter}, ConverterParameter=15}">
                <Line.Style>
                    <Style  TargetType="Line">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Nodes[3].IsVisible}" Value="False">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Line.Style>
            </Line>

            <ContentControl Template="{StaticResource GraphNode}" Content="{Binding Nodes[0]}" Name="Circle1" 
                            Canvas.Left="80" Canvas.Top="{Binding Nodes[0].Position}"/>
            <ContentControl Template="{StaticResource GraphNode}" Content="{Binding Nodes[1]}" Name="Circle2" 
                            Canvas.Left="200" Canvas.Top="{Binding Nodes[1].Position}"/>
            <ContentControl Template="{StaticResource GraphNode}" Content="{Binding Nodes[2]}" Name="Circle3" 
                            Canvas.Left="320" Canvas.Top="{Binding Nodes[2].Position}"/>
            <ContentControl Template="{StaticResource GraphNode}" Content="{Binding Nodes[3]}" Name="Circle4" 
                            Canvas.Left="440" Canvas.Top="{Binding Nodes[3].Position}"/>

            <Line X1="150" Y1="0" X2="150" Y2="350" Stroke="{StaticResource InputBackgroundBrush}"/>
            <Line X1="270" Y1="0" X2="270" Y2="350" Stroke="{StaticResource InputBackgroundBrush}"/>
            <Line X1="390" Y1="0" X2="390" Y2="350" Stroke="{StaticResource InputBackgroundBrush}"/>
            
            <Label Canvas.Bottom="0" Content="{Binding Times[0]}" Canvas.Left="80"
                   Foreground="{StaticResource InputBackgroundBrush}"/>
            <Label Canvas.Bottom="0" Content="{Binding Times[1]}" Canvas.Left="200"
                   Foreground="{StaticResource InputBackgroundBrush}"/>
            <Label Canvas.Bottom="0" Content="{Binding Times[2]}" Canvas.Left="320"
                   Foreground="{StaticResource InputBackgroundBrush}"/>
            <Label Canvas.Bottom="0" Content="{Binding Times[3]}" Canvas.Left="440"
                   Foreground="{StaticResource InputBackgroundBrush}"/>
        </Canvas>
    </Grid>
</UserControl>
