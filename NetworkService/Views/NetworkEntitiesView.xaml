<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:viewmodels="clr-namespace:NetworkService.ViewModel"
             xmlns:converters="clr-namespace:NetworkService.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <UserControl.DataContext>
        <viewmodels:NetworkEntitiesViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="1.6*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.8*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="0.8*"/>
                <RowDefinition Height="4.5*"/>
                
            </Grid.RowDefinitions>

            <Label Style="{StaticResource HeaderLabelStyle}"
                   Content="Filter Nodes"
                   HorizontalAlignment="Left"/>

            <Grid Background="{StaticResource BackgroundBrush}"
                  Margin="5"
                  Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1.8*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    
                    <Label Content="Filter by"
                           Style="{StaticResource LabelInputStyle}"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Content="Name"
                                     GroupName="Search"
                                     IsChecked="{Binding SearchByName}"
                                     Margin="5"/>

                        <RadioButton Grid.Row="1"
                                     Content="Type" 
                                     GroupName="Search"
                                     Margin="5"
                                     Grid.Column="1"/>
                    </Grid>
                </Grid>
                
                <Label Grid.Row="1">
                    <Label.Style>
                        <Style TargetType="Label" BasedOn="{StaticResource LabelInputStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchByName}" Value="True">
                                    <Setter Property="Content"
                                            Value="Name"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding SearchByName}" Value="False">
                                    <Setter Property="Content"
                                            Value="Type"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>
                </Label>


                <TextBox Grid.Row="2"
                         Text="{Binding SearchResourceName}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchByName}" Value="True">
                                    <Setter Property="Visibility" 
                                            Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchByName}" Value="False">
                                    <Setter Property="Visibility" 
                                            Value="Hidden"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                
                <ComboBox Grid.Row="2"
                          ItemsSource="{Binding EnergyResourceTypes}" 
                          SelectedItem="{Binding SearchResourceType}"
                          Margin="5 0 0 0"
                          Height="35">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource ComboStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchByName}" Value="True">
                                    <Setter Property="Visibility" 
                                                Value="Hidden"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchByName}" Value="False">
                                    <Setter Property="Visibility" 
                                                Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <Button Grid.Column="1"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        VerticalAlignment="Bottom"
                        Content="Search"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource ConfirmButtonStyle}"
                        Foreground="White"
                        Background="{StaticResource BorderBrush}"/>
                
                <Button Grid.Column="1" 
                        Grid.Row="2" 
                        Content="Clear"
                        Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource CancelButtonStyle}"/>
            </Grid>

            <Label Grid.Row="2"
                   Style="{StaticResource HeaderLabelStyle}"
                   Content="Add Node"
                   HorizontalAlignment="Left"/>

            <Grid Grid.Row="3"
                  Margin="5"
                  Background="{StaticResource BackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition/>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition Height="1.2*"/>
                </Grid.RowDefinitions>

                <Label Content="Name"
                       Style="{StaticResource LabelInputStyle}"/>
                
                <TextBox  Text="{Binding CreateEnergyResource.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          Grid.Row="1"
                          Style="{StaticResource InputTextBoxStyle}"
                          MaxLength="20"/>
                <Label Content="{Binding CreateEnergyResource.ValidationErrors[Name]}"
                       Foreground="Red"
                       Grid.Row="1" Grid.Column="1"
                       Style="{StaticResource ErrorLabel}"/>

                <Label Content="Type" Grid.Row="2"
                       Style="{StaticResource LabelInputStyle}"/>
                
                <ComboBox ItemsSource="{Binding EnergyResourceTypes}" 
                          SelectedItem="{Binding CreateEnergyResource.Type, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          Grid.Row="3"
                          Margin="5 0 0 0"
                          Style="{StaticResource ComboStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Content="{Binding CreateEnergyResource.ValidationErrors[Type]}"
                       Foreground="Red"
                       Grid.Row="3"
                       Grid.Column="1"
                       Style="{StaticResource ErrorLabel}"/>

                <Button Content="Add" 
                        Grid.Column="1" 
                        Grid.Row="4"
                        Command="{Binding CreateCommand}"
                        Style="{StaticResource ConfirmButtonStyle}"
                        Foreground="White"
                        Background="{StaticResource BorderBrush}"/>
            </Grid>
            
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.9*"/>
                <RowDefinition Height="8*"/>
            </Grid.RowDefinitions>

            <Button HorizontalAlignment="Right"
                    Content="Delete"
                    Margin="0 0 5 0"
                    IsTabStop="False"
                    Command="{Binding DeleteCommand}"
                    IsEnabled="{Binding SelectedResource, Converter={StaticResource NullToBoolConverter}}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ConfirmButtonStyle}">
                        <Setter Property="Background"
                                Value="{StaticResource BorderBrush}"/>
                        <Setter Property="Foreground"
                                Value="White"/>
                    </Style>
                </Button.Style>
            </Button>
            
            <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding EnergyResources}"
                      SelectedItem="{Binding SelectedResource, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                <DataGrid.InputBindings>
                    <KeyBinding Key="Delete"
                                Command="{Binding DeleteCommand}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id"
                                        Width="*"
                                        Binding="{Binding Id}"
                                        IsReadOnly="True"/>
                    
                    <DataGridTextColumn Header="Name"
                                        Width="2*"
                                        Binding="{Binding Name}"
                                        IsReadOnly="True"/>
                    
                    <DataGridTextColumn Header="Type"
                                        Width="2*"
                                        Binding="{Binding Type.Name}"
                                        IsReadOnly="True"/>
                    
                    <DataGridTemplateColumn Width="*"
                                            Header="Value (MW)"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}"
                                           HorizontalAlignment="Right"
                                           Margin="0 0 5 0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
