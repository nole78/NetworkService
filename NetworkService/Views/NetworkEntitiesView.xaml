<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             xmlns:viewmodels="clr-namespace:NetworkService.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <UserControl.DataContext>
        <viewmodels:NetworkEntitiesViewModel/>
    </UserControl.DataContext>
    
    <Grid Background="white">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="1.6*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="3*"/>
                <RowDefinition/>
                <RowDefinition Height="5*"/>
            </Grid.RowDefinitions>

            <Label Style="{StaticResource HeaderLabelStyle}"
                   Content="Filter Nodes"
                   HorizontalAlignment="Left"/>

            <Grid Background="Gray" 
                  Margin="5"
                  Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="1.5*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <RadioButton Content="Name"
                                 GroupName="Search"
                                 IsChecked="{Binding SearchByName}"
                                 Margin="5"/>

                    <RadioButton Grid.Row="1"
                                 Content="Type" 
                                 GroupName="Search"
                                 Margin="5"/>
                </Grid>

                <Label>
                    <Label.Style>
                        <Style TargetType="Label">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchByName}" Value="True">
                                    <Setter Property="Content"
                                            Value="Name"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding SearchByName}" Value="False">
                                    <Setter Property="Content"
                                            Value="Type"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>    
                </Label>
                    
                <TextBox Grid.Row="1"
                         Text="{Binding SearchResourceName}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchByName}" Value="True">
                                    <Setter Property="Visibility" 
                                            Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchByName}" Value="False">
                                    <Setter Property="Visibility" 
                                            Value="Hidden"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                
                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding EnergyResourceTypes}" 
                          SelectedItem="{Binding SearchResourceType}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchByName}" Value="True">
                                    <Setter Property="Visibility" 
                                                Value="Hidden"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchByName}" Value="False">
                                    <Setter Property="Visibility" 
                                                Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <Button Grid.Column="1"
                        Grid.Row="1"
                        Content="Search"
                        Command="{Binding SearchCommand}"/>
                
                <Button Grid.Column="1" 
                        Grid.Row="2" 
                        Content="Clear"
                        Command="{Binding ClearSearchCommand}"/>
            </Grid>

            <Label Grid.Row="2"
                   Style="{StaticResource HeaderLabelStyle}"
                   Content="Add Node"
                   HorizontalAlignment="Left"/>

            <Grid Grid.Row="3"
                  Background="Gray"
                  Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition/>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition Height="1.8*"/>
                </Grid.RowDefinitions>

                <Label Content="Name"/>
                <TextBox  Text="{Binding CreateEnergyResource.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          Grid.Row="1"/>
                <Label Content="{Binding CreateEnergyResource.ValidationErrors[Name]}"
                       Foreground="Red"
                       Grid.Row="1" Grid.Column="1"/>

                <Label Content="Type" Grid.Row="2"/>
                <ComboBox ItemsSource="{Binding EnergyResourceTypes}" 
                          SelectedItem="{Binding CreateEnergyResource.Type, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          Grid.Row="3">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Content="{Binding CreateEnergyResource.ValidationErrors[Type]}"
                       Foreground="Red"
                       Grid.Row="3"
                       Grid.Column="1"/>

                <Button Content="Add" 
                        Grid.Column="1" 
                        Grid.Row="4"
                        Command="{Binding CreateCommand}"/>
            </Grid>
            
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="8*"/>
            </Grid.RowDefinitions>
            
            <Button HorizontalAlignment="Right"
                    Content="Delete"
                    Margin="0 0 5 0"
                    Command="{Binding DeleteCommand}"/>
            
            <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding EnergyResources}"
                      AutoGenerateColumns="False"
                      SelectedItem="{Binding SelectedResource}"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id"
                                        Width="*"
                                        Binding="{Binding Id}"
                                        IsReadOnly="True"/>
                    
                    <DataGridTextColumn Header="Name"
                                        Width="2*"
                                        Binding="{Binding Name}"
                                        IsReadOnly="True"/>
                    
                    <DataGridTextColumn Header="Type"
                                        Width="2*"
                                        Binding="{Binding Type.Name}"
                                        IsReadOnly="True"/>
                    
                    <DataGridTemplateColumn Width="*"
                                            Header="Value (MW)">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}"
                                           HorizontalAlignment="Right"
                                           Margin="0 0 5 0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
