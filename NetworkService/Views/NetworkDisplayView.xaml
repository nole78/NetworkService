<UserControl x:Class="NetworkService.Views.NetworkDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             xmlns:model="clr-namespace:NetworkService.Model"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:viewmodels="clr-namespace:NetworkService.ViewModel"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <viewmodels:NetworkDisplayViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <ControlTemplate x:Key="Node" TargetType="ContentControl">
            <Border Margin="5" BorderBrush="Black" BorderThickness="2" CornerRadius="5" ClipToBounds="True">
                <Grid Background="LightGray">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <fa5:SvgAwesome Icon="Solid_ExclamationTriangle" 
                                    Panel.ZIndex="2" 
                                    Foreground="Red"
                                    Width="30"
                                    Height="30"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right">
                        <fa5:SvgAwesome.Style>
                            <Style TargetType="fa5:SvgAwesome">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Content.IsAlarm, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </fa5:SvgAwesome.Style>
                    </fa5:SvgAwesome>
                    <Canvas Panel.ZIndex="1">
                        <Canvas.Background>
                            <ImageBrush ImageSource="{Binding Content.Type.ImagePath, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Canvas.Background>
                    </Canvas>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding Content.Id, RelativeSource={RelativeSource TemplatedParent}, StringFormat='Id: #{0}'}"/>
                        <TextBlock Text="{Binding Content.Value, RelativeSource={RelativeSource TemplatedParent}, StringFormat=' {0} MW'}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="8*"/>
        </Grid.RowDefinitions>

        <Label Style="{StaticResource  HeaderLabelStyle}"
           Content="Resources"
           HorizontalAlignment="Left"
           Margin="5 0 0 0"/>
        <TreeView Grid.Row="1" 
                  Margin="5"
                  ItemsSource="{Binding TreeViewNodes}">
            <behaviors:Interaction.Triggers>
                <behaviors:EventTrigger EventName="SelectedItemChanged">
                    <behaviors:CallMethodAction TargetObject="{Binding}"
                                                MethodName="OnDragStart"/>
                </behaviors:EventTrigger>
            </behaviors:Interaction.Triggers>
            
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type viewmodels:TreeViewTypeGroup}"
                                          ItemsSource="{Binding Resources}">
                    <TextBlock FontWeight="SemiBold" Text="{Binding TypeName}"/>
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type model:DistributedEnergyResource}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Id, StringFormat='#{0} '}"/>
                        <TextBlock Text="{Binding Name}"/>
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>


        <Label Grid.Column="1"
           Style="{StaticResource HeaderLabelStyle}"
           Content="Network"
           HorizontalAlignment="Left"
           Margin="5 0 0 0"/>

        <Grid Grid.Column="1"
          Grid.Row="1"
          Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <ContentControl Template="{StaticResource Node}"
                            Content="{Binding Slots[0]}"
                            AllowDrop="True"
                            Tag="0">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>
            
            <ContentControl Template="{StaticResource Node}" Grid.Column="1"
                            Content="{Binding Slots[1]}"
                            AllowDrop="True"
                            Tag="1">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Column="2"
                            Content="{Binding Slots[2]}"
                            AllowDrop="True"
                            Tag="2">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Column="3"
                            Content="{Binding Slots[3]}"
                            AllowDrop="True"
                            Tag="3">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Row="1"
                            Content="{Binding Slots[4]}"
                            AllowDrop="True"
                            Tag="4">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Row="1" Grid.Column="1"
                            Content="{Binding Slots[5]}"
                            AllowDrop="True"
                            Tag="5">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Row="1" Grid.Column="2"
                            Content="{Binding Slots[6]}"
                            AllowDrop="True"
                            Tag="6">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Row="1" Grid.Column="3"
                            Content="{Binding Slots[7]}"
                            AllowDrop="True"
                            Tag="7">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Row="2"
                            Content="{Binding Slots[8]}"
                            AllowDrop="True"
                            Tag="8">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Row="2" Grid.Column="1"
                            Content="{Binding Slots[9]}"
                            AllowDrop="True"
                            Tag="9">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Row="2" Grid.Column="2"
                            Content="{Binding Slots[10]}"
                            AllowDrop="True"
                            Tag="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

            <ContentControl Template="{StaticResource Node}" Grid.Row="2" Grid.Column="3"
                            Content="{Binding Slots[11]}"
                            AllowDrop="True"
                            Tag="11">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </ContentControl>

        </Grid>
    </Grid>
</UserControl>
