<UserControl x:Class="NetworkService.Views.NetworkDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             xmlns:model="clr-namespace:NetworkService.Model"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:viewmodels="clr-namespace:NetworkService.ViewModel"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:NetworkService.Converters"
             mc:Ignorable="d" 
             x:Name="RootView"
             d:DesignHeight="400" d:DesignWidth="800">
    <UserControl.DataContext>
        <viewmodels:NetworkDisplayViewModel/>
    </UserControl.DataContext>

    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding EnterCommand}"
                    CommandParameter="{Binding ElementName=FirstSlot}"/>
        
        <KeyBinding Key="Escape" Command="{Binding CancelSelectionCommand}"/>

        <KeyBinding Key="Up" Command="{Binding MoveFocusCommand}" CommandParameter="Up"/>
        <KeyBinding Key="Down" Command="{Binding MoveFocusCommand}" CommandParameter="Down"/>
        <KeyBinding Key="Left" Command="{Binding MoveFocusCommand}" CommandParameter="Left"/>
        <KeyBinding Key="Right" Command="{Binding MoveFocusCommand}" CommandParameter="Right"/>
    </UserControl.InputBindings>

    <UserControl.Resources>
        <converters:SlotToPositionConverter x:Key="SlotToPositionConverter"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <ControlTemplate x:Key="Node" TargetType="ContentControl">
            <Border Margin="5" 
                    BorderThickness="2" 
                    ClipToBounds="True" 
                    AllowDrop="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush"
                                Value="{StaticResource BorderBrush}"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Content.IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter Property="BorderBrush"
                                        Value="{StaticResource SelectedBorderBrush}"/>
                                <Setter Property="BorderThickness"
                                        Value="4"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content.IsKeyboardFocused, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter Property="BorderBrush" Value="Orange"/>
                                <Setter Property="BorderThickness" Value="5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.DrawMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Cursor"
                                        Value="Pen"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    MethodName="OnDrop"/>
                    </behaviors:EventTrigger>

                    <behaviors:EventTrigger EventName="PreviewMouseLeftButtonDown">
                        <behaviors:CallMethodAction TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    MethodName="OnGridDragStart"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>


                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Background"
                                    Value="{StaticResource BackgroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Content.IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                    <Setter Property="Background"
                                            Value="LightBlue"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <fa5:SvgAwesome Icon="Solid_ExclamationTriangle" 
                                    Panel.ZIndex="2" 
                                    Foreground="Red"
                                    Width="30"
                                    Height="30"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right">
                        <fa5:SvgAwesome.Style>
                            <Style TargetType="fa5:SvgAwesome">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Content.Resource.IsAlarm, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </fa5:SvgAwesome.Style>
                    </fa5:SvgAwesome>
                    <Canvas Panel.ZIndex="1">
                        <Canvas.Background>
                            <ImageBrush ImageSource="{Binding Content.Resource.Type.ImagePath, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Canvas.Background>
                    </Canvas>
                    <Canvas Panel.ZIndex="1"
                            Width="50"
                            ToolTip="Area to drag and drop resource in"
                            Height="50">
                        <Canvas.Style>
                            <Style TargetType="Canvas">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Content.Resource, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToBoolConverter}}" Value="True" >
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Canvas.Style>
                        <Canvas.Background>
                            <ImageBrush ImageSource="/Assets/drop_here.png"/>
                        </Canvas.Background>
                    </Canvas>

                    <Grid Grid.Row="1" 
                          Panel.ZIndex="10">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Background" 
                                        Value="{StaticResource TextInputBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Content.IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                        <Setter Property="Background"
                                                Value="CadetBlue"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Button Width="30" Height="30"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                VerticalAlignment="Center"
                                Command="{Binding DataContext.RemoveFromGridCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Content.Resource.Id, RelativeSource={RelativeSource TemplatedParent}}">
                            <fa5:SvgAwesome Icon="Solid_WindowClose"
                                            Foreground="{StaticResource ErrorBorderBrush}"/>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Content.Resource, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToBoolConverter}}" Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding DataContext.DrawMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="{Binding Content.Resource.Id, RelativeSource={RelativeSource TemplatedParent}, StringFormat='#{0}'}"
                                   Grid.Column="1"
                                   Style="{StaticResource SlotDescriptionStyle}"/>
                        <TextBlock Text="{Binding Content.Resource.Value, RelativeSource={RelativeSource TemplatedParent}, StringFormat=' {0} MW'}"
                                   Grid.Column="2"
                                   Style="{StaticResource SlotDescriptionStyle}"/>
                    </Grid>
                </Grid>
            </Border>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DrawMode}" Value="True">
                        <Setter Property="Background"
                                Value="{StaticResource DrawingModBrush}"/>
                        <Setter Property="Cursor"
                                Value="Pen"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="8*"/>
        </Grid.RowDefinitions>

        <Label Content="Resources"
               HorizontalAlignment="Left"
               Margin="5 0 0 0">
            <Label.Style>
                <Style TargetType="Label" BasedOn="{StaticResource HeaderLabelStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DrawMode}" Value="True">
                            <Setter Property="Opacity"
                                Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Label.Style>
        </Label>

        <TreeView Grid.Row="1" 
                  Margin="5"
                  ItemsSource="{Binding TreeViewNodes}"
                  Cursor="Arrow">

            <behaviors:Interaction.Triggers>
                <behaviors:EventTrigger EventName="SelectedItemChanged">
                    <behaviors:ChangePropertyAction TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            PropertyName="SelectedTreeResource" 
                                            Value="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
                </behaviors:EventTrigger>
            </behaviors:Interaction.Triggers>
            
            <TreeView.Style>
                <Style TargetType="TreeView" BasedOn="{StaticResource TreeViewStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.DrawMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Cursor"
                                    Value="No"/>
                            <Setter Property="IsTabStop"
                                    Value="False"/>
                            <Setter Property="Opacity"
                                    Value="0.4"/>
                            <Setter Property="IsEnabled"
                                    Value="False"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DataContext.IsSelectingSlotMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Focusable" 
                                    Value="False"/>
                            <Setter Property="IsTabStop" 
                                    Value="False"/>
                            <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="None"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.Style>

            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type viewmodels:TreeViewTypeGroup}"
                                          ItemsSource="{Binding Resources}">
                    <TextBlock FontWeight="SemiBold" Text="{Binding TypeName}"/>
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type model:DistributedEnergyResource}">
                    <StackPanel Orientation="Horizontal" Cursor="Hand">

                        <behaviors:Interaction.Triggers>
                            <behaviors:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                <behaviors:CallMethodAction TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            MethodName="OnDragStart"/>
                            </behaviors:EventTrigger>
                        </behaviors:Interaction.Triggers>

                        <TextBlock Text="{Binding Id, StringFormat='#{0} '}"
                                   Foreground="White"
                                   FontWeight="ExtraBold"/>
                        <TextBlock Text="{Binding Name}"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Label Content="Network"
                   HorizontalAlignment="Left"
                   Margin="5 0 0 0">
                <Label.Style>
                    <Style TargetType="Label" BasedOn="{StaticResource HeaderLabelStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DrawMode}" Value="True">
                                <Setter Property="Foreground"
                                        Value="DarkBlue"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>

            <Button Grid.Column="1"
                    Width="120"
                    ToolTip="Press Esc to exit"
                    Height="35"
                    Command="{Binding CancelSelectionCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ConfirmButtonStyle}">
                        <Setter Property="Visibility"
                                Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelectingSlotMode}" Value="True">
                                <Setter Property="Visibility"
                                        Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Background>
                    <SolidColorBrush Color="#FFE8BF21" Opacity="0.4"/>
                </Button.Background>
                <TextBlock Text="Selection Mode"
                       Foreground="DarkOrange"
                       FontFamily="Calibri"
                       FontSize="16"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                </TextBlock>
            </Button>

            <Button Grid.Column="2"
                    HorizontalAlignment="Right"
                    Margin="0 0 5 0"
                    ToolTip="Turn Drawing mode on"
                    TabIndex="0"
                    Command="{Binding DrawModeChangeCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ConfirmButtonStyle}">
                        <Setter Property="Content"
                                Value="Draw Mode: Off"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DrawMode}" Value="True">
                                <Setter Property="Content"
                                        Value="Draw Mode: On"/>
                                <Setter Property="Background"
                                        Value="{StaticResource SelectedBorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <Grid Grid.Column="1"
          Grid.Row="1"
          Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <ItemsControl ItemsSource="{Binding Connections}" 
                          Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="4" 
                          Panel.ZIndex="2" 
                          IsHitTestVisible="False"
                          IsTabStop="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Name="LineCanvas" IsItemsHost="True" Background="Transparent"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Line Stroke="Blue" StrokeThickness="3">
                            <Line.X1>
                                <MultiBinding Converter="{StaticResource SlotToPositionConverter}" ConverterParameter="X">
                                    <Binding Path="FromSlot"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Canvas}"/>
                                </MultiBinding>
                            </Line.X1>

                            <Line.Y1>
                                <MultiBinding Converter="{StaticResource SlotToPositionConverter}" ConverterParameter="Y">
                                    <Binding Path="FromSlot"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Canvas}"/>
                                </MultiBinding>
                            </Line.Y1>

                            <Line.X2>
                                <MultiBinding Converter="{StaticResource SlotToPositionConverter}" ConverterParameter="X">
                                    <Binding Path="ToSlot"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Canvas}"/>
                                </MultiBinding>
                            </Line.X2>

                            <Line.Y2>
                                <MultiBinding Converter="{StaticResource SlotToPositionConverter}" ConverterParameter="Y">
                                    <Binding Path="ToSlot"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Canvas}"/>
                                </MultiBinding>
                            </Line.Y2>
                        </Line>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ContentControl Template="{StaticResource Node}"
                            Content="{Binding Slots[0]}"
                            AllowDrop="True"
                            Tag="0"
                            Name="FirstSlot"/>

            <ContentControl Template="{StaticResource Node}" Grid.Column="1"
                            Content="{Binding Slots[1]}"
                            AllowDrop="True"
                            Tag="1"/>

            <ContentControl Template="{StaticResource Node}" Grid.Column="2"
                            Content="{Binding Slots[2]}"
                            AllowDrop="True"
                            Tag="2"/>

            <ContentControl Template="{StaticResource Node}" Grid.Column="3"
                            Content="{Binding Slots[3]}"
                            AllowDrop="True"
                            Tag="3"/>

            <ContentControl Template="{StaticResource Node}" Grid.Row="1"
                            Content="{Binding Slots[4]}"
                            AllowDrop="True"
                            Tag="4"/>

            <ContentControl Template="{StaticResource Node}" Grid.Row="1" Grid.Column="1"
                            Content="{Binding Slots[5]}"
                            AllowDrop="True"
                            Tag="5"/>

            <ContentControl Template="{StaticResource Node}" Grid.Row="1" Grid.Column="2"
                            Content="{Binding Slots[6]}"
                            AllowDrop="True"
                            Tag="6"/>

            <ContentControl Template="{StaticResource Node}" Grid.Row="1" Grid.Column="3"
                            Content="{Binding Slots[7]}"
                            AllowDrop="True"
                            Tag="7"/>

            <ContentControl Template="{StaticResource Node}" Grid.Row="2"
                            Content="{Binding Slots[8]}"
                            AllowDrop="True"
                            Tag="8"/>

            <ContentControl Template="{StaticResource Node}" Grid.Row="2" Grid.Column="1"
                            Content="{Binding Slots[9]}"
                            AllowDrop="True"
                            Tag="9"/>

            <ContentControl Template="{StaticResource Node}" Grid.Row="2" Grid.Column="2"
                            Content="{Binding Slots[10]}"
                            AllowDrop="True"
                            Tag="10"/>

            <ContentControl Template="{StaticResource Node}" Grid.Row="2" Grid.Column="3"
                            Content="{Binding Slots[11]}"
                            AllowDrop="True"
                            Tag="11"/>

        </Grid>
    </Grid>
</UserControl>
