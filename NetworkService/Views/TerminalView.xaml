<UserControl x:Class="NetworkService.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             xmlns:viewmodels="clr-namespace:NetworkService.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="180" d:DesignWidth="790">
    
    <UserControl.DataContext>
        <viewmodels:TerminalViewModel/>
    </UserControl.DataContext>

    <Border BorderThickness="2" 
            BorderBrush="{StaticResource TextInputBrush}" 
            ClipToBounds="True"
            Width="790" Height="180">
    <Grid Background="Black"
          MouseDown="Grid_MouseDown">

        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Renewable_scada_terminal" TextAlignment="Center" FontSize="15" FontWeight="Bold" VerticalAlignment="Top"
                   FontFamily="Calibri" 
                   Background="{StaticResource HeaderBackgroundBrush}"
                   Foreground="{StaticResource HeaderTextBrush}"/>

        <StackPanel Grid.Row="1">
                <ListView x:Name="TerminalListView"
                          ItemsSource="{Binding TerminalLines, UpdateSourceTrigger=PropertyChanged}" 
                          MaxHeight="130" 
                          Background="Transparent"
                          BorderThickness="0"
                          SelectedItem="{Binding NewestLine}" 
                          SelectionChanged="TerminalListView_SelectionChanged" >
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>

                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter Margin="{TemplateBinding Padding}" 
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" FontSize="13" FontFamily="Consolas">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Command">
                                                <Setter Property="Foreground" Value="{StaticResource TextInputBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Error">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Success">
                                                <Setter Property="Foreground" Value="LimeGreen"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Question">
                                                <Setter Property="Foreground" Value="Yellow"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            <StackPanel Orientation="Horizontal">
                <Label Content="renewable__scada__terminal>"
                       Foreground="{StaticResource InputBackgroundBrush}"   
                       FontSize="13"
                       FontFamily="Consolas"
                       VerticalContentAlignment="Center"/>
                <TextBox Text="{Binding  Command, UpdateSourceTrigger=PropertyChanged}" 
                         Name="TerminalInput"
                         Background="Transparent" 
                         Foreground="{StaticResource InputBackgroundBrush}"
                         VerticalAlignment="Center"
                         BorderThickness="0" 
                         FontSize="13" 
                         FontFamily="Consolas"
                         Width="600"
                         CaretBrush="{StaticResource HeaderBackgroundBrush}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ExecuteTerminalCommand}"/>
                        <KeyBinding Key="Up" Command="{Binding GetOlderCommand}"/>
                        <KeyBinding Key="Down" Command="{Binding GetNewerCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
            </StackPanel>
        </StackPanel>
    </Grid>
    </Border>
</UserControl>
